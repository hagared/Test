{
  "name": "ZombieSurvival",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      }
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "Client": {
          "$path": "src/client"
        }
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "Gravity": 196.2,
        "FilteringEnabled": true
      }
    },
    "Lighting": {
      "$className": "Lighting",
      "$properties": {
        "Ambient": [0.15, 0.15, 0.2],
        "OutdoorAmbient": [0.4, 0.4, 0.45],
        "Brightness": 1.5,
        "ClockTime": 2.5,
        "FogColor": [0.1, 0.1, 0.15],
        "FogStart": 50,
        "FogEnd": 400
      }
    },
    "SoundService": {
      "$className": "SoundService",
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
